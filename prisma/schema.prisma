// Full schema with Vehicle.damages

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}



model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  name            String?
  password        String
  role            String   @default("employee") // admin, manager, employee
  pin             String?  // 4-6 digit PIN for quick login
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sales           Sale[]
  drawerTransactions DrawerTransaction[]
  timeLogs        EmployeeTimeLog[]
}

model EmployeeTimeLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String   // clock_in, clock_out
  timestamp DateTime @default(now())
  notes     String?
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  quantity    Int      @default(0)
  category    String   // storeroom, bakery, auto
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BakeryItem {
  id               Int      @id @default(autoincrement())
  name             String
  type             String   // machinery, equipment, supplies
  description      String?
  quantity         Int      @default(0)
  desiredStockLevel Int     @default(0)  // Desired stock level for alerts
  expirationDate   String?  // For supplies that expire
  purchaseLocation String?  // Where the item was purchased (physical store)
  website          String?  // Website where the item can be ordered from
  dateOfEntry      DateTime @default(now())
  lastUpdated      DateTime @updatedAt
  lastStockUpdate  DateTime? // Last time stock was added/removed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AutoPart {
  id               Int       @id @default(autoincrement())
  name             String
  make             String?
  model            String?   // Vehicle model
  year             Int?      // Vehicle year
  partNumber       String?
  description      String?
  quantity         Int       @default(0)
  price            Float?
  photo            String?
  licensePlate     String?
  vin              String?
  purchaseLocation String?   // Where the part was purchased (physical store)
  website          String?   // Website where the part can be ordered from
  desiredStockLevel Int     @default(0)  // Desired stock level for alerts
  zone             String?   // Warehouse storage zone (e.g., A1, B2, C3)
  reorderTime      Int?      // Average days to reorder (for forecasting)
  dateOfEntry      DateTime  @default(now())  // When the part was first entered
  lastUpdated      DateTime  @updatedAt  // Last time the part was edited
  lastStockUpdate  DateTime? // Last time stock was added/removed
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  saleItems        SaleItem[]
}

model Sale {
  id              Int       @id @default(autoincrement())
  saleDate        DateTime  @default(now())
  subtotal        Float     // Total before tax and discount
  taxAmount       Float     @default(0)  // Sales tax amount
  taxRate         Float     @default(0)  // Tax rate percentage (e.g., 8.25 for 8.25%)
  discountAmount  Float     @default(0)  // Discount amount
  discountType    String?   // 'percentage' or 'fixed'
  discountValue   Float?    // The discount value applied
  totalAmount     Float
  paymentMethod   String?   // cash, card, split, gift_card, etc.
  cashTendered    Float?    // Amount of cash received
  changeGiven     Float?    // Change given back
  customerName    String?
  customerPhone   String?
  customerEmail   String?   // For digital receipts
  notes           String?
  receiptNumber   String?   // Unique receipt number
  employeeId      Int?      // Who processed the sale
  employee        User?     @relation(fields: [employeeId], references: [id])
  customerId      Int?      // Link to customer
  customer        Customer? @relation(fields: [customerId], references: [id])
  items           SaleItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Suspended/Held sales that can be recalled later
model SuspendedSale {
  id              Int       @id @default(autoincrement())
  suspendDate     DateTime  @default(now())
  subtotal        Float
  taxAmount       Float     @default(0)
  taxRate         Float     @default(0)
  discountAmount  Float     @default(0)
  discountType    String?
  discountValue   Float?
  totalAmount     Float
  customerName    String?
  customerPhone   String?
  notes           String?
  saleKey        String    // Key to recall sale (e.g., "SALE-001")
  items           SuspendedSaleItem[]
}

model SuspendedSaleItem {
  id                Int           @id @default(autoincrement())
  suspendedSaleId   Int
  suspendedSale     SuspendedSale @relation(fields: [suspendedSaleId], references: [id])
  autoPartId        Int
  quantity          Int
  unitPrice         Float
  subtotal          Float
}

// Cash drawer transactions (no sale, drawer opens, etc.)
model DrawerTransaction {
  id            Int       @id @default(autoincrement())
  timestamp     DateTime  @default(now())
  type          String    // no_sale, drop, pickup, cash_in, cash_out
  amount        Float     // Amount added or removed
  notes         String?
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
}

// Customer model for loyalty and tracking
model Customer {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String?
  email           String?
  totalPurchases  Float     @default(0)
  points          Int       @default(0)  // Loyalty points
  visitCount      Int       @default(0)
  lastVisit       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sales           Sale[]
}

model SaleItem {
  id              Int       @id @default(autoincrement())
  saleId          Int
  sale            Sale      @relation(fields: [saleId], references: [id])
  autoPartId      Int
  autoPart        AutoPart  @relation(fields: [autoPartId], references: [id])
  quantity        Int
  unitPrice       Float
  subtotal        Float
  createdAt       DateTime  @default(now())
}

model Vehicle {
  id           Int           @id @default(autoincrement())
  make         String
  model        String
  year         Int
  vin          String        @unique
  licensePlate String
  color        String?
  status       String?       @default("Available")
  category     String?
  transmissionType String?
  fuelType     String?
  currentOdometerReading Int?
  nextServiceDueDate DateTime?
  notes        String?
  maintenances Maintenance[]
  damages      ClientDamage[] @relation("VehicleDamages")
  rentalAgreements VehicleRentalAgreement[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Maintenance {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  type        String   // oil change, tire rotation, etc.
  description String?
  date        DateTime
  nextDue     DateTime?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Property {
  id            Int               @id @default(autoincrement())
  propertyId    String            @unique // e.g., "APT101", "ROOM205"
  name          String            // "Studio Apartment 1A"
  description   String?
  address       String
  occupancyLimit Int              // Max number of occupants
  rentAmount    Float
  depositAmount Float?            // Security deposit
  amenities     String?           // "wifi, parking, pool"
  furnishingType String? // unfurnished, semi_furnished, fully_furnished
  status        String             @default("AVAILABLE")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  agreements    RentalAgreement[]
  payments      RentalPayment[]
  householdItems HouseholdItem[]
}

model HouseholdItem {
  id           Int      @id @default(autoincrement())
  propertyId   Int
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  description  String
  quantity     Int
  conditionNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id                    Int              @id @default(autoincrement())
  name                  String
  phone                 String?
  email                 String?
  idNumber              String?          // Government ID
  idPhoto               String?          // Path to uploaded ID photo
  requiresSecurityDeposit Boolean         @default(true)
  securityDepositAmount Float? 
  securityDepositCollected Boolean        @default(false)
  emergencyContact       String?
  isBlacklisted         Boolean          @default(false)
  blacklistReason        String?
  blacklistUntil        DateTime?        // null = indefinite
  blacklistBy           Int?             // Admin user ID
  blacklistDate         DateTime? 
  createdAt             DateTime         @default(now())
  agreements            RentalAgreement[]

  @@unique([name, idNumber])
}

model VehicleRentalAgreement {
  id                Int                  @id @default(autoincrement())
  agreementNumber   String               @unique
  vehicleId         Int
  rentalClientId    Int
  agreementType     String  // 'daily' | 'weekly' | 'monthly' | 'fixed-lease'
  startDate         DateTime
  endDate           DateTime?
  dailyAmount       Float?
  weeklyAmount      Float?
  monthlyAmount     Float?
  leaseAmount       Float?
  depositAmount     Float?
  lateFee           Float?
  lateFeeAfterDays  Int?
  balance           Float                @default(0)
  status            String               @default("active")
  notes             String?
  createdAt         DateTime             @default(now())
  
  vehicle           Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  rentalClient      RentalClient         @relation(fields: [rentalClientId], references: [id], onDelete: Cascade)
}

model RentalAgreement {
  id             Int      @id @default(autoincrement())
  agreementNumber String @unique // "RA-2026-001"
  propertyId     Int
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantId       Int
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime?
  rentAmount     Float
  depositAmount  Float
  status         String          @default("ACTIVE")
  terms          String?          // Rental terms and conditions
  createdAt      DateTime         @default(now())
  signedAt       DateTime?
  payments       RentalPayment[]
}

model RentalPayment {
  id            Int      @id @default(autoincrement())
  agreementId   Int
  agreement     RentalAgreement @relation(fields: [agreementId], references: [id])
  propertyId    Int?
  property      Property? @relation(fields: [propertyId], references: [id])
  amount        Float
  paymentDate   DateTime @default(now())
  method        String   // cash, transfer, check
  receiptNumber String?
  notes         String?
}

model RentalClient {
  id                    Int              @id @default(autoincrement())
  name                  String
  phone                 String?
  email                 String?
  driversLicenseNumber  String?
  driversLicensePhoto   String?
  preferredVehicle      String?
  emergencyContact      String?
  balance               Float            @default(0)
  isBlacklisted         Boolean          @default(false)
  blacklistReason       String?
  blacklistUntil        DateTime?
  blacklistBy           Int?
  blacklistDate         DateTime? 
  createdAt             DateTime         @default(now())

  damages              ClientDamage[]
  payments             ClientPayment[]
  rentalAgreements      VehicleRentalAgreement[]

  @@unique([name, driversLicenseNumber])
}

model ClientDamage {
  id                 Int       @id @default(autoincrement())
  rentalClientId     Int
  rentalClient       RentalClient @relation(fields: [rentalClientId], references: [id], onDelete: Cascade)
  vehicleId          Int?
  vehicle            Vehicle?       @relation("VehicleDamages", fields: [vehicleId], references: [id])
  description        String
  amount             Float
  date               DateTime  @default(now())
  accidentDate       DateTime?
  accidentLocation   String?
  vehiclesInvolved   String?
  payerName          String?
  payerAddress       String?
  receiverName       String?
  receiverAddress    String?
  status             String    @default("pending") // pending, paid, waived
  notes              String?
  createdAt          DateTime  @default(now())
}

model ClientPayment {
  id                   Int       @id @default(autoincrement())
  rentalClientId       Int
  rentalClient         RentalClient @relation(fields: [rentalClientId], references: [id], onDelete: Cascade)
  amount               Float
  paymentDate          DateTime  @default(now())
  method               String    // cash, card, bank
  notes                String?
  totalAgreementAmount Float?
  installmentNumber    Int?
  totalInstallments    Int?
  dueDate              DateTime?
  lateFeeAmount        Float?
  lateFeeRate          Float?
  createdAt            DateTime  @default(now())
}

